<%
  const cover = post.cover || (typeof postCover === 'function' ? postCover(post) : '');
  const hasCover = (theme.endspace && theme.endspace.post_list_cover !== false) && cover;
  const showPreview = (theme.endspace && theme.endspace.post_list_preview !== false);
  const dateStr = post.date ? date(post.date, 'YYYY-MM-DD') : '';
  const categoryName = post.categories && post.categories.length ? post.categories.data[0].name : '';
  const tags = post.tags && post.tags.length ? post.tags.data.slice(0, 3).map(function(t){ return t.name; }) : [];
  const summary = truncate(strip_html(post.excerpt || post.description || post.content || ''), { length: 220, separator: ' ', omission: '…' });
%>
<a href="<%- url_for(post.path) %>" class="block">
  <article class="endspace-frame group mb-6 flex flex-col md:flex-row overflow-hidden relative transition-all duration-300">
    <% if (hasCover) { %>
      <div class="w-full md:w-48 aspect-video flex-shrink-0 relative overflow-hidden z-10 bg-black/5">
        <img src="<%= cover %>" alt="<%= post.title %>"
             class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700">
        <div class="absolute top-3 right-3 w-2 h-2 bg-[var(--endspace-accent-yellow)] opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </div>
    <% } %>

    <div class="flex-1 flex flex-col justify-center relative z-10 p-5 md:p-6 overflow-hidden">
      <div class="absolute inset-0 bg-[#FBFB45] transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-out z-0"></div>

      <div class="relative z-10">
        <div class="flex items-center gap-3 text-xs font-mono text-[var(--endspace-text-muted)] mb-3 group-hover:text-black/60 transition-colors">
          <span class="text-[var(--endspace-text-primary)] font-bold group-hover:text-black transition-colors"><%= dateStr %></span>
          <span class="w-px h-3 bg-[var(--endspace-border-base)] group-hover:bg-black/30 transition-colors"></span>
          <% if (categoryName) { %><span class="tracking-wider"><%= categoryName.toUpperCase() %></span><% } %>
        </div>

        <h2 class="text-2xl md:text-3xl font-black text-[var(--endspace-text-primary)] mb-4 leading-tight group-hover:text-black transition-colors">
          <%= post.title %>
        </h2>

        <% if (showPreview && summary) { %>
          <p class="text-[var(--endspace-text-secondary)] text-sm leading-relaxed line-clamp-2 md:line-clamp-3 mb-6 font-medium group-hover:text-black/70 transition-colors">
            <%= summary %>
          </p>
        <% } %>

        <div class="mt-auto flex items-center justify-between">
          <div class="flex gap-2">
            <% tags.forEach(function(t){ %>
              <span class="text-[10px] text-[var(--endspace-text-muted)] bg-[var(--endspace-bg-secondary)] px-1.5 py-0.5 rounded group-hover:bg-black group-hover:text-white transition-colors">#<%= t %></span>
            <% }); %>
          </div>
          <div class="flex items-center gap-2 text-[var(--endspace-text-primary)] text-xs font-bold uppercase tracking-wider group-hover:gap-3 transition-all group-hover:text-black">
            <span>Access</span>
            <%- icon('arrow_right', { size: 12 }) %>
          </div>
        </div>
      </div>
    </div>
  </article>
</a>
