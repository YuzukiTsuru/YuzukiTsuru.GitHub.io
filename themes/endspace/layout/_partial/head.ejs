<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<% var pageTitle = page.title || ''; // Generator pages set i18n keys as title (prefixed with "title_") if (pageTitle.indexOf('title_') === 0) pageTitle = __(pageTitle); // 404 page if (page.path && page.path.indexOf('404') !== -1) pageTitle = '404'; %>
<title><%= pageTitle ? (pageTitle + ' · ' + config.title) : config.title %></title>
<meta
  name="description"
  content="<%= page.description || page.excerpt || config.description || '' %>"
/>
<meta name="keywords" content="<%= (page.keywords || config.keywords || '') %>" />
<meta name="generator" content="Hexo + Endspace" />
<% if (config.url) { %>
<meta property="og:title" content="<%= pageTitle || config.title %>" />
<meta
  property="og:description"
  content="<%= page.description || page.excerpt || config.description || '' %>"
/>
<meta property="og:type" content="<%= page.layout === 'post' ? 'article' : 'website' %>" />
<meta property="og:url" content="<%- url_for(page.path) %>" />
<% if (page.cover) { %><meta property="og:image" content="<%= page.cover %>" /><% } %> <% } %>

<link rel="icon" type="image/png" href="<%- url_for(theme.favicon || '/images/logo.png') %>" />
<% if (config.feed) { %>
<link
  rel="alternate"
  type="application/atom+xml"
  title="<%= config.title %>"
  href="<%- url_for('/atom.xml') %>"
/>
<% } %>

<!-- Fonts (local) -->
<link rel="stylesheet" href="<%- url_for('/css/vendor/inter.css') %>" />
<link rel="stylesheet" href="<%- url_for('/css/vendor/jetbrains-mono.css') %>" />

<!-- Icons (local) -->
<link rel="stylesheet" href="<%- url_for('/css/vendor/remixicon.css') %>" />
<link rel="stylesheet" href="<%- url_for('/css/vendor/fontawesome.min.css') %>" />

<!-- Tailwind CSS (precompiled) -->
<link rel="stylesheet" href="<%- url_for('/css/tailwind.css') %>" />

<!-- Theme CSS -->
<link rel="stylesheet" href="<%- url_for('/css/endspace.css') %>" />

<!-- Search index location -->
<meta name="aic-search-path" content="<%- url_for('/search.xml') %>" />

<% if (page.mathjax) { %>
<script>
  // Pre-process: decode HTML entities in $$ blocks before MathJax sees them
  (function() {
    var decodeEntities = function(str) {
      return str.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>');
    };
    var walk = function(node) {
      if (node.nodeType === 3) {
        var text = node.textContent;
        if (text.indexOf('$') !== -1) {
          node.textContent = text.replace(/\$\$[\s\S]*?\$\$/g, decodeEntities);
        }
      } else if (node.nodeType === 1 && !/^(SCRIPT|STYLE|CODE|PRE)$/.test(node.tagName)) {
        for (var i = 0; i < node.childNodes.length; i++) {
          walk(node.childNodes[i]);
        }
      }
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { walk(document.body); });
    } else {
      walk(document.body);
    }
  })();
  MathJax = {
    tex: {
      inlineMath: [['$', '$']],
      displayMath: [['$$', '$$'], ['\\[', '\\]']],
      processEnvironments: true,
      processRefs: true
    },
    options: {
      skipHtmlTags: ['noscript', 'style', 'textarea', 'pre', 'code'],
      ignoreHtmlClass: 'tex2jax_ignore'
    },
    svg: { fontCache: 'global' },
    loader: { load: ['[tex]/mhchem'] }
  };
</script>
<script
  id="MathJax-script"
  async
  src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"
></script>
<% } %>

<% if (page.plot) { %>
<script src="<%- url_for('/js/vendor/d3.min.js') %>"></script>
<script src="<%- url_for('/js/vendor/function-plot.js') %>"></script>
<% } %>
