<div class="endspace-frame p-8 md:p-12 mb-12">
  <% if (page.title) { %>
  <h1
    class="text-3xl md:text-5xl font-black text-[var(--endspace-text-primary)] mb-6 uppercase tracking-wide"
  >
    <%= page.title %>
  </h1>
  <% } %>
  <div class="promotion-grid">
    <% var proms = site.data.promotion && site.data.promotion.prom; %> <% if (proms && proms.length)
    { %> <% proms.forEach(function(prom) { %>
    <a href="<%= prom.link %>" target="_blank" rel="noopener" class="promotion-card">
      <% if (prom.img) { %>
      <img src="<%- url_for(prom.img) %>" alt="<%= prom.name %>" class="promotion-img" />
      <% } %>
      <div class="promotion-name"><%= prom.name %></div>
      <% if (prom.desc) { %>
      <div class="promotion-desc"><%= prom.desc %></div>
      <% } %>
    </a>
    <% }) %>
    <% } %>
  </div>
</div>
