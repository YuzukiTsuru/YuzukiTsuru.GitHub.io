<div class="mb-8">
  <div class="flex items-center gap-3 border-b border-[var(--endspace-border-base)] pb-3 mb-4">
    <div class="w-1 h-6 bg-[var(--endspace-accent-yellow)]"></div>
    <h2 class="text-2xl md:text-3xl font-black tech-text text-[var(--endspace-text-primary)] uppercase">
      TAG: #<%= page.tag %>
    </h2>
    <span class="text-xs tech-text text-[var(--endspace-text-muted)] ml-auto">// <%= page.posts.length %>_ENTRIES</span>
  </div>
</div>

<div id="posts-wrapper">
  <% page.posts.each(function(post){ %>
    <%- partial('_partial/blog-post-card', { post: post }) %>
  <% }); %>
</div>
<%- partial('_partial/pagination') %>
